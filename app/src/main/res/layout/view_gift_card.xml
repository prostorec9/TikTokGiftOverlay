<?xml version="1.0" encoding="utf-8"?>
<!--
    Карточка подарка — точь-в-точь как на скриншоте TikTok LIVE
    Тёмный полупрозрачный фон, аватарка слева, иконка подарка справа
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_background"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_gift_card"
    android:clipToPadding="false">

    <!-- Аватарка пользователя (круглая) -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/avatar_image"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_avatar_placeholder"
        app:civ_border_width="2dp"
        app:civ_border_color="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Блок текста: ник и действие -->
    <LinearLayout
        android:id="@+id/text_block"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/gift_image"
        app:layout_constraintStart_toEndOf="@+id/avatar_image"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Имя пользователя -->
        <TextView
            android:id="@+id/nickname_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="username"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <!-- "sent Rose" -->
        <TextView
            android:id="@+id/action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="sent Rose"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Иконка подарка справа (Rose 🌹, Coral 🪸, итд) -->
    <ImageView
        android:id="@+id/gift_image"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_gift_placeholder"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
