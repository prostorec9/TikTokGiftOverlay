<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="380dp"
    android:layout_height="90dp">

    <!-- Тёмная таблетка-фон -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gift_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="0dp"
        android:paddingEnd="12dp">

        <!-- Аватарка — большая, вписана в таблетку слева -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/avatar_image"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_avatar_placeholder"
            app:civ_border_width="0dp" />

        <!-- Имя пользователя по центру -->
        <TextView
            android:id="@+id/nickname_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="username"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <!-- Иконка подарка справа — большая -->
        <ImageView
            android:id="@+id/gift_image"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_gift_placeholder"
            android:scaleType="fitCenter"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Скрытый TextView для совместимости с кодом -->
    <TextView
        android:id="@+id/action_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</FrameLayout>
